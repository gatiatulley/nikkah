<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Али & Лейсан — Никах</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#fbf7f2;
  --card:rgba(255,255,255,0.75);
  --text:#5d4b3d;
  --soft:#8b7765;
  --gold:#b89b6a;
  --border:rgba(184,155,106,0.18);
}

*{margin:0;padding:0;box-sizing:border-box;}

body{
  font-family:Montserrat,sans-serif;
  background:linear-gradient(180deg,#fffaf2,#f6efe6);
  color:var(--text);
  overflow-x:hidden;
}

.container{
  width:min(1050px,92%);
  margin:auto;
}

section{
  padding:90px 0;
}

/* HERO */
.hero{
  min-height:100vh;
  display:flex;
  align-items:center;
  text-align:center;
  position:relative;
}

.hero h1{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(52px,8vw,110px);
  letter-spacing:1px;
}

.date{
  margin-top:18px;
  font-size:22px;
  color:var(--soft);
}

/* CARD */
.card{
  background:var(--card);
  backdrop-filter:blur(14px);
  border:1px solid var(--border);
  border-radius:28px;
  padding:42px;
  box-shadow:0 20px 60px rgba(0,0,0,0.06);
  transition:.4s ease;
}

.card:hover{
  transform:translateY(-4px);
  box-shadow:0 30px 80px rgba(0,0,0,0.08);
}

/* TIMER */
.timer{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(130px,1fr));
  gap:18px;
  margin-top:35px;
}

.timer-box{
  background:rgba(255,255,255,0.8);
  border-radius:22px;
  padding:22px;
}

.timer-box span{
  font-family:'Cormorant Garamond',serif;
  font-size:40px;
  color:var(--gold);
  display:block;
}

/* TITLE */
h2{
  font-family:'Cormorant Garamond',serif;
  font-size:44px;
  margin-bottom:18px;
  text-align:center;
}

/* SCHEDULE */
.schedule{
  display:grid;
  gap:18px;
}

.schedule-item{
  padding:18px;
  border-left:2px solid var(--gold);
  background:rgba(255,255,255,0.5);
  border-radius:14px;
}

.schedule-item h3{
  font-size:26px;
  margin-bottom:4px;
}

/* DRESS */
.dress-title{
  font-family:'Cormorant Garamond',serif;
  font-size:26px;
  margin-top:18px;
}

.dress-text{
  color:var(--soft);
  margin-top:6px;
  line-height:1.7;
}

.dress-divider{
  height:1px;
  background:var(--border);
  margin:16px 0;
}

/* MAP */
iframe{
  width:100%;
  height:420px;
  border:none;
  border-radius:24px;
  margin-top:24px;
}

/* FOOTER */
.footer{
  text-align:center;
  padding:100px 0;
}

.rsvp{
  display:inline-block;
  margin-top:26px;
  padding:14px 32px;
  border-radius:999px;
  background:var(--gold);
  color:#fff;
  text-decoration:none;
}

/* ===== ANIMATIONS ===== */
.reveal{
  opacity:0;
  transform:translateY(24px);
  transition:all 1s cubic-bezier(.2,.8,.2,1);
}

.reveal.show{
  opacity:1;
  transform:translateY(0);
}
</style>
</head>

<body>

<section class="hero reveal">
  <div class="container">
    <h1>Али & Лейсан</h1>
    <div class="date">9 августа 2026 • 13:00</div>
  </div>
</section>

<section class="reveal">
  <div class="container">
    <div class="card">
      <h2>До никаха осталось</h2>
      <div class="timer" id="timer"></div>
    </div>
  </div>
</section>

<section class="reveal">
  <div class="container">
    <div class="card">
      <h2>Программа дня</h2>

      <div class="schedule">

        <div class="schedule-item">
          <h3>14:00 — Никах</h3>
          <p>Мечеть</p>
        </div>

        <div class="schedule-item">
          <h3>15:00 — Welcome-зона и фуршет</h3>
          <p>Банкетный зал</p>
        </div>

        <div class="schedule-item">
          <h3>15:30 — Банкет</h3>
          <p>Банкетный зал</p>
        </div>

      </div>

      <h2 style="margin-top:40px;">Локации</h2>

      <iframe src="https://yandex.ru/map-widget/v1/?um=constructor%3A1f261cb09e038d5c6bee1c49ec5485177f3ad43a4e426fd3060439c6a79b5e41"></iframe>

    </div>
  </div>
</section>

<section class="reveal">
  <div class="container">
    <div class="card">

      <h2>Dress Code</h2>

      <p class="dress-title">Общий стиль</p>
      <p class="dress-text">
        Мы будем рады видеть вас в нарядной одежде светлых, спокойных оттенков.
      </p>

      <div class="dress-divider"></div>

      <p class="dress-title">Церемония</p>
      <p class="dress-text">
        Сдержанный и элегантный образ, прикрытые плечи, руки и ноги.
      </p>

      <p class="dress-text">
        Для девушек будут предоставлены платки.
      </p>

      <div class="dress-divider"></div>

      <p class="dress-title">Банкет</p>
      <p class="dress-text">
        Более свободный, но эстетичный и светлый стиль.
      </p>

    </div>
  </div>
</section>

<section class="footer reveal">
  <div class="container">
    <h2>Будем рады видеть вас</h2>
    <a class="rsvp" href="#">Подтвердить присутствие</a>
  </div>
</section>

<script>
/* TIMER */
const weddingDate = new Date("2026-08-09T13:00:00").getTime();
const timer = document.getElementById("timer");

function updateTimer(){
  const now = Date.now();
  const diff = weddingDate - now;

  const d = Math.floor(diff/86400000);
  const h = Math.floor(diff/3600000%24);
  const m = Math.floor(diff/60000%60);
  const s = Math.floor(diff/1000%60);

  timer.innerHTML = `
    <div class="timer-box"><span>${d}</span>дней</div>
    <div class="timer-box"><span>${h}</span>часов</div>
    <div class="timer-box"><span>${m}</span>минут</div>
    <div class="timer-box"><span>${s}</span>секунд</div>
  `;
}
setInterval(updateTimer,1000);
updateTimer();

/* SCROLL REVEAL */
const observer = new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.classList.add("show");
    }
  });
},{threshold:0.15});

document.querySelectorAll(".reveal").forEach(el=>{
  observer.observe(el);
});
</script>

</body>
</html>
